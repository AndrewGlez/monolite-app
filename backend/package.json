{
  "name": "backend",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "dotenv -e ../.env.local -- tsx watch src/server.ts",
    "build": "tsdown src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "db:generate": "dotenv -e ../.env.local -- prisma generate",
    "db:push": "dotenv -e ../.env.local -- prisma db push",
    "db:migrate": "dotenv -e ../.env.local -- prisma migrate dev",
    "db:studio": "dotenv -e ../.env.local -- prisma studio",
    "db:seed": "dotenv -e ../.env.local -- tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcryptjs": "^3.0.0",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "prisma": "^7.4.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.0",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.7",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.20.0",
    "prettier": "^3.8.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2",
    "vitest": "^3.0.0"
  }
}
